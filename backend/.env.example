# ============================================================
# 电子衣橱 CloudBase 环境变量
# 复制此文件为 .env 并填入真实值
# ============================================================

# JWT 签名密钥（生产环境请使用 openssl rand -hex 32 生成）
JWT_SECRET=electronic-wardrobe-jwt-secret-2026

# 微信小程序 AppSecret（从微信公众平台获取）
WX_APP_SECRET=your-app-secret-here
